### Test Metric Entry API

### Variables
@baseUrl = http://localhost:3000/api/v1
@adminToken = change-me
###############################################################################
### SETUP: Create all dependent entities
###############################################################################

### Create a service type
# @name createServiceType
POST {{baseUrl}}/service-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Metric Test Service Type {{$guid}}",
    "propertySchema": {
        "properties": {
            "cpu": {
                "type": "integer",
                "label": "CPU Cores",
                "required": true
            },
            "memory": {
                "type": "integer",
                "label": "Memory (MB)",
                "required": true
            }
        }
    },
    "lifecycleSchema": {
        "states": [
            {"name": "New"},
            {"name": "Created"},
            {"name": "Started"},
            {"name": "Stopped"},
            {"name": "Deleted"}
        ],
        "actions": [
            {
                "name": "create",
                "requestSchemaType": "properties",
                "transitions": [
                    {"from": "New", "to": "Created"}
                ]
            },
            {
                "name": "start",
                "transitions": [
                    {"from": "Created", "to": "Started"},
                    {"from": "Stopped", "to": "Started"}
                ]
            },
            {
                "name": "stop",
                "transitions": [
                    {"from": "Started", "to": "Stopped"}
                ]
            },
            {
                "name": "delete",
                "transitions": [
                    {"from": "Stopped", "to": "Deleted"},
                    {"from": "Created", "to": "Deleted"}
                ]
            }
        ],
        "initialState": "New",
        "terminalStates": ["Deleted"],
        "runningStates": ["Started"]
    }
}

### Create an agent type
# @name createAgentType
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Metric Test Agent Type {{$guid}}",
    "serviceTypeIds": [
        "{{createServiceType.response.body.id}}"
    ],
    "configurationSchema": {
        "properties": {
            "endpoint": {
                "type": "string",
                "label": "Endpoint",
                "required": true
            }
        }
    }
}

### Create a provider
# @name createProvider
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Provider {{$guid}}",
    "status": "Enabled",
    "attributes": {
        "type": ["test"]
    }
}

### Create an agent
# @name createAgent
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Agent {{$guid}}",
    "agentTypeId": "{{createAgentType.response.body.id}}",
    "providerId": "{{createProvider.response.body.id}}",
    "configuration": {
        "endpoint": "https://test.example.com"
    }
}

@agentId = {{createAgent.response.body.id}}

### Create a new agent token
# @name createAgentToken
POST {{baseUrl}}/tokens
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Agent Token",
    "role": "agent",
    "expireAt": "{{$datetime iso8601 1 y}}",
    "scopeId": "{{agentId}}"
}

@agentToken = {{createAgentToken.response.body.value}}

### Create a new consumer
# @name createConsumer
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Consumer {{$guid}}",
    "status": "Enabled"
}

### Create a service group
# @name createServiceGroup
POST {{baseUrl}}/service-groups
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Job Service Group {{$guid}}",
    "consumerId": "{{createConsumer.response.body.id}}"
}

### Create a new service
# @name createService
POST {{baseUrl}}/services
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Service {{$guid}}",
    "agentId": "{{agentId}}",
    "serviceTypeId": "{{createServiceType.response.body.id}}",
    "groupId": "{{createServiceGroup.response.body.id}}",
    "properties": {
        "cpu": 4,
        "memory": 512
    }
}

@serviceId = {{createService.response.body.id}}

###############################################################################
### JOB LIFECYCLE: Pending → Claim → Complete
###############################################################################

### Get pending jobs for agent
# @name pendingJobs
GET {{baseUrl}}/jobs/pending
Authorization: Bearer {{agentToken}}

@jobId = {{pendingJobs.response.body.$[0].id}}

### Claim a job
POST {{baseUrl}}/jobs/{{jobId}}/claim
Authorization: Bearer {{agentToken}}

### Complete a job
# @name completeJob
POST {{baseUrl}}/jobs/{{jobId}}/complete
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "agentInstanceData": {
        "status": "success",
        "details": {
            "duration": "10s",
            "output": "Service started successfully"
        }
    },
    "agentInstanceId": "{{$guid}}"
}

### Get a service by ID
# @name getService
GET {{baseUrl}}/services/{{serviceId}}
Authorization: Bearer {{adminToken}}

@agentInstanceId = {{getService.response.body.agentInstanceId}}

###############################################################################
### METRIC ENTRY TESTING
###############################################################################

### Create a metric type for testing
# @name createMetricType
POST {{baseUrl}}/metric-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "test-metric {{$guid}}",
    "entityType": "Service"
}

@metricTypeId = {{createMetricType.response.body.id}}
@metricTypeName = {{createMetricType.response.body.name}}

### Create a new metric entry using serviceId
# @name createMetricEntry
POST {{baseUrl}}/metric-entries
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "serviceId": "{{serviceId}}",
    "resourceId": "test-resource",
    "value": 35.5,
    "typeName": "{{metricTypeName}}"
}

### Create a new metric entry using externalId
# @name createMetricEntryByName
POST {{baseUrl}}/metric-entries
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "agentInstanceId": "{{agentInstanceId}}",
    "resourceId": "test-resource",
    "value": 78.2,
    "typeName": "{{metricTypeName}}"
}

### List all metric entries
GET {{baseUrl}}/metric-entries
Authorization: Bearer {{adminToken}}

### List metric entries with pagination
GET {{baseUrl}}/metric-entries?page=1&pageSize=10
Authorization: Bearer {{adminToken}}

### Get unique resource IDs
GET {{baseUrl}}/metric-entries/resource-ids?serviceId={{serviceId}}&typeId={{metricTypeId}}&agentId={{agentId}}
Authorization: Bearer {{adminToken}}

###############################################################################
### AGGREGATE TESTING
###############################################################################

### Aggregate with defaults (aggregateType=min, bucket=hour)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}
Authorization: Bearer {{adminToken}}

### Aggregate with explicit params (hour bucket, 7 day max range)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?aggregateType=max&bucket=hour&start=2026-03-07T00:00:00Z&end=2026-03-13T23:59:59Z
Authorization: Bearer {{adminToken}}

### Aggregate with avg and day bucket
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?aggregateType=avg&bucket=day
Authorization: Bearer {{adminToken}}

### Aggregate with sum and minute bucket
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?aggregateType=sum&bucket=minute
Authorization: Bearer {{adminToken}}

### Aggregate with month bucket
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?aggregateType=min&bucket=month
Authorization: Bearer {{adminToken}}

###############################################################################
### TIME RANGE VALIDATION TESTING
###############################################################################

### ERROR: end time before start time (expect 400)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?start=2026-03-13T00:00:00Z&end=2026-03-01T00:00:00Z
Authorization: Bearer {{adminToken}}

### ERROR: minute bucket exceeds 24h max range (expect 400)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=minute&start=2026-03-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### ERROR: hour bucket exceeds 7 day max range (expect 400)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=hour&start=2026-01-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### ERROR: day bucket exceeds 3 month max range (expect 400)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=day&start=2025-01-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### ERROR: month bucket exceeds 1 year max range (expect 400)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=month&start=2024-01-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### OK: minute bucket within 24h range (expect 200)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=minute&start=2026-03-12T12:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### OK: hour bucket within 7 day range (expect 200)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=hour&start=2026-03-07T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### OK: day bucket within 3 month range (expect 200)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=day&start=2026-01-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}

### OK: month bucket within 1 year range (expect 200)
GET {{baseUrl}}/metric-entries/aggregate/{{serviceId}}/test-resource/{{metricTypeId}}?bucket=month&start=2025-06-01T00:00:00Z&end=2026-03-13T00:00:00Z
Authorization: Bearer {{adminToken}}
