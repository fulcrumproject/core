### Config Pool Value Operations
### This file tests operations for config pool values

### Variables
@baseUrl = http://localhost:3000/api/v1
@adminToken = change-me

### Create an config pool (needed for config pool values)
# @name createConfigPool
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Test Pool",
  "type": "publicIp",
  "propertyType": "string",
  "generatorType": "list"
}

@configPoolId = {{createConfigPool.response.body.$.id}}

### Get all config pool values
GET {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}

### Get all config pool values with filter by name
GET {{baseUrl}}/config-pool-values?name=192
Authorization: Bearer {{adminToken}}

### Get all config pool values with filter by configPoolId
GET {{baseUrl}}/config-pool-values?configPoolId={{configPoolId}}
Authorization: Bearer {{adminToken}}

### Get all config pool values with filter by agentId
GET {{baseUrl}}/config-pool-values?agentId=change-me
Authorization: Bearer {{adminToken}}

### Create an config pool value
# @name createConfigPoolValue
POST {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "192.168.1.10",
  "value": "192.168.1.10",
  "configPoolId": "{{configPoolId}}"
}

@configPoolValueId = {{createConfigPoolValue.response.body.$.id}}

### Get a specific config pool value
GET {{baseUrl}}/config-pool-values/{{configPoolValueId}}
Authorization: Bearer {{adminToken}}

###############################################################################
### Auth: global pool (admin-only) vs participant-scoped pool
###############################################################################
### Verifies the recent auth work:
###   - List filter applier hides other-scope rows from a participant.
###   - AuthScope returns AdminOnlyObjectScope for global pool values (403).
###   - AuthScope returns the owning DefaultObjectScope for scoped values (200).

### Create a participant that will own the scoped pool
# @name createScopedParticipant
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Config Pool Participant",
  "status": "Enabled"
}

@scopedParticipantId = {{createScopedParticipant.response.body.$.id}}

### Issue a participant-scoped token
# @name createScopedParticipantToken
POST {{baseUrl}}/tokens
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Participant Token",
  "role": "participant",
  "expireAt": "{{$datetime iso8601 1 y}}",
  "scopeId": "{{scopedParticipantId}}"
}

@participantToken = {{createScopedParticipantToken.response.body.value}}

### Create a participant-scoped pool (participantId set => non-global)
# @name createScopedPool
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Participant Pool",
  "type": "scopedIp",
  "propertyType": "string",
  "generatorType": "list",
  "participantId": "{{scopedParticipantId}}"
}

@scopedPoolId = {{createScopedPool.response.body.$.id}}

### Seed a value in the scoped pool
# @name createScopedValue
POST {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "10.0.0.1",
  "value": "10.0.0.1",
  "configPoolId": "{{scopedPoolId}}"
}

@scopedValueId = {{createScopedValue.response.body.$.id}}

### Participant LIST — expect only the scoped value; global value filtered out
GET {{baseUrl}}/config-pool-values
Authorization: Bearer {{participantToken}}

###  Participant GET on the global value — expect 403 (AdminOnlyObjectScope)
GET {{baseUrl}}/config-pool-values/{{configPoolValueId}}
Authorization: Bearer {{participantToken}}

###  Participant GET on their own scoped value — expect 200
GET {{baseUrl}}/config-pool-values/{{scopedValueId}}
Authorization: Bearer {{participantToken}}

### Delete an config pool value
DELETE {{baseUrl}}/config-pool-values/{{configPoolValueId}}
Authorization: Bearer {{adminToken}}

###############################################################################
### Pool generator end-to-end: allocation on agent Create, release on Delete
###############################################################################
### This walks through the `generator: "pool"` flow end-to-end:
###   1. Seed a pool and two values.
###   2. Declare an agent type whose configurationSchema has a pool-generated
###      property.
###   3. Create an agent → observe that the property gets auto-allocated.
###   4. Create a second agent → uses the second value.
###   5. Create a third agent → fails with "no available values in pool".
###   6. Delete the first agent → its value gets released.
###   7. Create a third agent → now succeeds using the released value.

### Create a provider for the pool-generator scenario
# @name createPoolGenProvider
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}

{
  "name": "Pool Generator Provider",
  "status": "Enabled"
}

@poolGenProviderId = {{createPoolGenProvider.response.body.$.id}}

### Create a pool dedicated to this scenario
# @name createPoolGenPool
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Generator Pool",
  "type": "publicIpGen",
  "propertyType": "string",
  "generatorType": "list"
}

@poolGenPoolId = {{createPoolGenPool.response.body.$.id}}

### Seed the pool with two values
# @name createPoolGenValue1
POST {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "203.0.113.10",
  "value": "203.0.113.10",
  "configPoolId": "{{poolGenPoolId}}"
}

@poolGenValueId1 = {{createPoolGenValue1.response.body.$.id}}

### Seed the pool with two values
# @name createPoolGenValue2
POST {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "203.0.113.11",
  "value": "203.0.113.11",
  "configPoolId": "{{poolGenPoolId}}"
}

@poolGenValueId2 = {{createPoolGenValue2.response.body.$.id}}

### Create an agent type that auto-allocates publicIP from the pool
# @name createPoolGenAgentType
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Generator Agent Type {{$timestamp}}",
  "configurationSchema": {
    "properties": {
      "publicIP": {
        "type": "string",
        "label": "Public IP",
        "generator": {
          "type": "pool",
          "config": {
            "poolType": "publicIpGen"
          }
        }
      }
    }
  }
}

@poolGenAgentTypeId = {{createPoolGenAgentType.response.body.$.id}}

### Create first agent — expect publicIP to be auto-allocated from the pool
# @name createPoolGenAgent1
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Gen Agent 1",
  "providerId": "{{poolGenProviderId}}",
  "agentTypeId": "{{poolGenAgentTypeId}}",
  "tags": ["pool-gen-test"],
  "configuration": {}
}

@poolGenAgent1Id = {{createPoolGenAgent1.response.body.$.id}}

### Verify agent 1 got a pool value in its configuration
GET {{baseUrl}}/agents/{{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}

### Verify agent 1 is stamped on one of the pool values
GET {{baseUrl}}/config-pool-values?agentId={{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}

### Create second agent — takes the remaining pool value
# @name createPoolGenAgent2
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Gen Agent 2",
  "providerId": "{{poolGenProviderId}}",
  "agentTypeId": "{{poolGenAgentTypeId}}",
  "tags": ["pool-gen-test"],
  "configuration": {}
}

@poolGenAgent2Id = {{createPoolGenAgent2.response.body.$.id}}

### Verify agent 2 configuration is populated
GET {{baseUrl}}/agents/{{poolGenAgent2Id}}
Authorization: Bearer {{adminToken}}

### List all values in the pool — both should be allocated
GET {{baseUrl}}/config-pool-values?configPoolId={{poolGenPoolId}}
Authorization: Bearer {{adminToken}}

### TEST: third agent fails — no available values in pool
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Gen Agent 3 (should fail)",
  "providerId": "{{poolGenProviderId}}",
  "agentTypeId": "{{poolGenAgentTypeId}}",
  "tags": ["pool-gen-test"],
  "configuration": {}
}

### Idempotent update — re-applying schema on update does NOT reallocate
PATCH {{baseUrl}}/agents/{{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "tags": ["pool-gen-test", "updated"]
}

### Verify agent 1 still holds its original pool value
GET {{baseUrl}}/agents/{{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}

### Delete agent 1 — expect its pool value to be released
DELETE {{baseUrl}}/agents/{{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}

### Verify agent 1's values were released (agentId filter should return empty)
GET {{baseUrl}}/config-pool-values?agentId={{poolGenAgent1Id}}
Authorization: Bearer {{adminToken}}

### List pool values — one should now be available again (agentId=null)
GET {{baseUrl}}/config-pool-values?configPoolId={{poolGenPoolId}}
Authorization: Bearer {{adminToken}}

### New agent now succeeds because the released value is available again
# @name createPoolGenAgent3
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Pool Gen Agent 3",
  "providerId": "{{poolGenProviderId}}",
  "agentTypeId": "{{poolGenAgentTypeId}}",
  "tags": ["pool-gen-test"],
  "configuration": {}
}

@poolGenAgent3Id = {{createPoolGenAgent3.response.body.$.id}}

### Confirm the previously released value is now stamped on agent 3
GET {{baseUrl}}/config-pool-values?agentId={{poolGenAgent3Id}}
Authorization: Bearer {{adminToken}}

###############################################################################
### Type uniqueness across global vs participant + type-based allocation
###############################################################################
### Verifies the cross-scope uniqueness rule and that allocation is resolved by
### type alone (whichever scope owns the type, globals included):
###   1. A type cannot exist as both global and participant — admin creates a
###      global pool of type T; provider attempt to create a participant pool
###      of type T returns 400.
###   2. Symmetric direction: provider creates participant pool of type T2;
###      admin attempt to create a global of T2 returns 400.
###   3. Agent under any provider whose AgentType references type T allocates
###      from the global pool of T (T is owned by the global scope, so the
###      global pool is the pool of T — no fallback involved).

### Static type used by both a global and a participant pool to trigger the
### conflict. Avoid {{$timestamp}} in @-vars (re-evaluated per request).
@scopedGenPoolType = scopedGenIp
@scopedGenPoolType2 = scopedGenIp2

### Participant cannot create a global pool (auth, not the new rule) — expect 403
POST {{baseUrl}}/config-pools
Authorization: Bearer {{participantToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Global Pool (forbidden)",
  "type": "{{scopedGenPoolType}}",
  "propertyType": "string",
  "generatorType": "list"
}

### Admin creates a global pool of type T
# @name createScopedGenGlobalPool
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Global Pool",
  "type": "{{scopedGenPoolType}}",
  "propertyType": "string",
  "generatorType": "list"
}

@scopedGenGlobalPoolId = {{createScopedGenGlobalPool.response.body.$.id}}

### Seed a value in the global pool (used by the fallback agent below)
POST {{baseUrl}}/config-pool-values
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "10.10.10.10",
  "value": "10.10.10.10",
  "configPoolId": "{{scopedGenGlobalPoolId}}"
}

### Create the provider that will exercise the cross-scope cases
# @name createScopedGenProvider
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Provider",
  "status": "Enabled"
}

@scopedGenProviderId = {{createScopedGenProvider.response.body.$.id}}

### CONFLICT: provider attempts to create a participant pool of type T — expect
### 400 with body "...already exists in global scope"
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Provider Pool (rejected)",
  "type": "{{scopedGenPoolType}}",
  "propertyType": "string",
  "generatorType": "list",
  "participantId": "{{scopedGenProviderId}}"
}

### Inverse direction: provider creates a participant pool of type T2
# @name createScopedGenProviderPool2
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Provider Pool T2",
  "type": "{{scopedGenPoolType2}}",
  "propertyType": "string",
  "generatorType": "list",
  "participantId": "{{scopedGenProviderId}}"
}

@scopedGenProviderPool2Id = {{createScopedGenProviderPool2.response.body.$.id}}

### CONFLICT: admin attempts to create a global pool of type T2 — expect 400
### with body "...already exists in participant <scopedGenProviderId> scope"
POST {{baseUrl}}/config-pools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Global Pool T2 (rejected)",
  "type": "{{scopedGenPoolType2}}",
  "propertyType": "string",
  "generatorType": "list"
}

### Agent type that requests a value of type T
# @name createScopedGenAgentType
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Agent Type {{$timestamp}}",
  "configurationSchema": {
    "properties": {
      "poolIp": {
        "type": "string",
        "label": "Pool IP",
        "generator": {
          "type": "pool",
          "config": {
            "poolType": "{{scopedGenPoolType}}"
          }
        }
      }
    }
  }
}

@scopedGenAgentTypeId = {{createScopedGenAgentType.response.body.$.id}}

### Agent under the provider — type T is owned by the global scope (the
### provider's same-type create was rejected above), so the agent allocates
### from the global pool (10.10.10.10)
# @name createScopedGenAgent
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Scoped Gen Agent (global fallback)",
  "providerId": "{{scopedGenProviderId}}",
  "agentTypeId": "{{scopedGenAgentTypeId}}",
  "configuration": {}
}

@scopedGenAgentId = {{createScopedGenAgent.response.body.$.id}}

### Inspect agent — poolIp must be 10.10.10.10 (allocated from the global pool of T)
GET {{baseUrl}}/agents/{{scopedGenAgentId}}
Authorization: Bearer {{adminToken}}

### Sanity: the global pool's value is now stamped on the agent
GET {{baseUrl}}/config-pool-values?agentId={{scopedGenAgentId}}
Authorization: Bearer {{adminToken}}
