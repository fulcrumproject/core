### Test Service Activation API

### Variables
@baseUrl = http://localhost:3000/api/v1
@adminToken = admin-test-token

### Create a provider for testing
# @name createProvider
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}

{
    "name": "Demo Service Provider",
    "status": "Enabled"
}

@providerId = {{createProvider.response.body.$.id}}

### Create an agent
# @name createAgent
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}

{
    "name": "VM Agent",
    "agentTypeId": "0195c3c6-4c7d-7e3c-b481-f276e17a7bec",
    "providerId": "{{providerId}}"
}

@agentId = {{createAgent.response.body.$.id}}

### Create a second agent for testing multiple agents
# @name createAgent2
POST {{baseUrl}}/agents
Authorization: Bearer {{adminToken}}

{
    "name": "Container Agent",
    "agentTypeId": "0195c3c6-4c7d-7e3c-b481-f276e17a7bec",
    "providerId": "{{providerId}}"
}

@agentId2 = {{createAgent2.response.body.$.id}}

### Create a service activation
# @name createServiceActivation
POST {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

{
    "providerId": "{{providerId}}",
    "serviceTypeId": "0195c3c8-69e5-7806-9598-8523c01ea54f",
    "tags": ["ISO 27001", "GPU"],
    "agentIds": ["{{agentId}}"]
}

@serviceActivationId = {{createServiceActivation.response.body.$.id}}

### Get service activation by ID
GET {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

### List all service activations
GET {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

### List service activations with provider filter
GET {{baseUrl}}/service-activations?provider_id={{providerId}}
Authorization: Bearer {{adminToken}}

### List service activations with service type filter
GET {{baseUrl}}/service-activations?service_type_id=0195c3c8-69e5-7806-9598-8523c01ea54f
Authorization: Bearer {{adminToken}}

### List service activations with tag filter
GET {{baseUrl}}/service-activations?tag=GPU
Authorization: Bearer {{adminToken}}

### Update service activation - add more tags and agents
PATCH {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

{
    "tags": ["ISO 27001", "GPU", "High-Memory", "SSD"],
    "agentIds": ["{{agentId}}", "{{agentId2}}"]
}

### Update service activation - tags only
PATCH {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

{
    "tags": ["ISO 27001", "Enterprise", "Certified"]
}

### Update service activation - agents only
PATCH {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

{
    "agentIds": ["{{agentId}}"]
}

### Get updated service activation
GET {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

### Create another service activation for different service type
# @name createServiceActivation2
POST {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

{
    "providerId": "{{providerId}}",
    "serviceTypeId": "0195c3c8-69e5-7806-9598-8523c01ea54f",
    "tags": ["Basic", "Standard"],
    "agentIds": ["{{agentId2}}"]
}

@serviceActivationId2 = {{createServiceActivation2.response.body.$.id}}

### List all service activations (should show both)
GET {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

### Delete second service activation
DELETE {{baseUrl}}/service-activations/{{serviceActivationId2}}
Authorization: Bearer {{adminToken}}

### Verify deletion - should return 404
GET {{baseUrl}}/service-activations/{{serviceActivationId2}}
Authorization: Bearer {{adminToken}}

### Delete first service activation
DELETE {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

### Verify deletion - should return 404
GET {{baseUrl}}/service-activations/{{serviceActivationId}}
Authorization: Bearer {{adminToken}}

### List all service activations (should be empty or not include deleted ones)
GET {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

### ===== SERVICE CREATION WITH SERVICE ACTIVATIONS =====

### Create a consumer participant for service creation
# @name createConsumer
POST {{baseUrl}}/participants
Authorization: Bearer {{adminToken}}

{
    "name": "Demo Service Consumer",
    "status": "Enabled"
}

@consumerId = {{createConsumer.response.body.$.id}}

### Create a service group for the consumer
# @name createServiceGroup
POST {{baseUrl}}/service-groups
Authorization: Bearer {{adminToken}}

{
    "name": "Test Service Group",
    "consumerId": "{{consumerId}}"
}

@serviceGroupId = {{createServiceGroup.response.body.$.id}}

### Recreate service activation for service creation testing
# @name createServiceActivationForServices
POST {{baseUrl}}/service-activations
Authorization: Bearer {{adminToken}}

{
    "providerId": "{{providerId}}",
    "serviceTypeId": "0195c3c8-69e5-7806-9598-8523c01ea54f",
    "tags": ["ISO 27001", "SOC 2 Type II", "Enterprise"],
    "agentIds": ["{{agentId}}"]
}

@serviceActivationIdForServices = {{createServiceActivationForServices.response.body.$.id}}

### Create service using service activation discovery (with tags)
# @name createServiceWithTags
POST {{baseUrl}}/services
Authorization: Bearer {{adminToken}}

{
    "groupId": "{{serviceGroupId}}",
    "serviceTypeId": "0195c3c8-69e5-7806-9598-8523c01ea54f",
    "serviceTags": ["ISO 27001", "SOC 2 Type II"],
    "name": "Service Created via Activation Discovery",
    "properties": {
        "cpu": "4",
        "memory": "8GB",
        "storage": "100GB"
    }
}

@serviceIdFromActivation = {{createServiceWithTags.response.body.$.id}}

### Create service using direct agent specification
# @name createServiceWithAgent
POST {{baseUrl}}/services
Authorization: Bearer {{adminToken}}

{
    "groupId": "{{serviceGroupId}}",
    "agentId": "{{agentId}}",
    "serviceTypeId": "0195c3c8-69e5-7806-9598-8523c01ea54f",
    "name": "Service Created via Direct Agent",
    "properties": {
        "cpu": "2",
        "memory": "4GB",
        "storage": "50GB"
    }
}

@serviceIdFromAgent = {{createServiceWithAgent.response.body.$.id}}

### Get service created via activation discovery
GET {{baseUrl}}/services/{{serviceIdFromActivation}}
Authorization: Bearer {{adminToken}}

### Get service created via direct agent
GET {{baseUrl}}/services/{{serviceIdFromAgent}}
Authorization: Bearer {{adminToken}}

### List all services
GET {{baseUrl}}/services
Authorization: Bearer {{adminToken}}
