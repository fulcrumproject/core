### Agent Type CRUD Operations
### This file tests CRUD operations for agent types

### Variables
@baseUrl = http://localhost:3000/api/v1
@adminToken = change-me
@participantToken = participant-test-token

### Get all agent types
GET {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}

### Create a new agent type with configuration schema
# @name createAgentType
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Test Agent Type",
    "configurationSchema": {
        "properties": {
            "apiEndpoint": {
                "type": "string",
                "label": "API Endpoint",
                "required": true,
            "validators": [
                {
                    "type": "pattern",
                    "config": {
                        "pattern": "^https?://"
                    }
                }
            ]
            },
            "apiKey": {
                "type": "string",
                "label": "API Key",
                "required": true,
                "secret": {
                    "type": "persistent"
                }
            },
            "maxRetries": {
                "type": "integer",
                "label": "Maximum Retries",
                "default": 3,
            "validators": [
                {
                    "type": "min",
                    "config": {
                        "value": 0
                    }
                },
                {
                    "type": "max",
                    "config": {
                        "value": 10
                    }
                }
            ]
            },
            "pollingInterval": {
                "type": "integer",
                "label": "Polling Interval (seconds)",
                "default": 30,
            "validators": [
                {
                    "type": "min",
                    "config": {
                        "value": 5
                    }
                }
            ]
            },
            "enableMetrics": {
                "type": "boolean",
                "label": "Enable Metrics Collection",
                "default": true
            },
            "logLevel": {
                "type": "string",
                "label": "Log Level",
                "default": "info",
            "validators": [
                {
                    "type": "enum",
                    "config": {
                        "values": ["debug", "info", "warn", "error"]
                    }
                }
            ]
            }
        }
    },
    "configTemplate": "apiEndpoint={{.apiEndpoint}}\napiKey={{.apiKey}}\nmaxRetries={{.maxRetries}}\npollingInterval={{.pollingInterval}}\nenableMetrics={{.enableMetrics}}\nlogLevel={{.logLevel}}",
    "cmdTemplate": "agent install --config {{.configUrl}} --poll {{.pollingInterval}}",
    "configContentType": "text/plain"
}

@createdAgentTypeId = {{createAgentType.response.body.id}}

### Get the created agent type
GET {{baseUrl}}/agent-types/{{createdAgentTypeId}}
Authorization: Bearer {{adminToken}}

### Update the agent type (PATCH)
# @name updateAgentType
PATCH {{baseUrl}}/agent-types/{{createdAgentTypeId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Updated Test Agent Type",
    "configurationSchema": {
        "properties": {
            "apiEndpoint": {
                "type": "string",
                "label": "API Endpoint",
                "required": true,
            "validators": [
                {
                    "type": "pattern",
                    "config": {
                        "pattern": "^https?://"
                    }
                }
            ]
            },
            "apiKey": {
                "type": "string",
                "label": "API Key",
                "required": true,
                "secret": {
                    "type": "persistent"
                }
            },
            "maxRetries": {
                "type": "integer",
                "label": "Maximum Retries",
                "default": 5,
                "validators": [
                    {
                        "type": "min",
                        "config": {
                            "value": 0
                        }
                    },
                    {
                        "type": "max",
                        "config": {
                            "value": 20
                        }
                    }
                ]
            },
            "pollingInterval": {
                "type": "integer",
                "label": "Polling Interval (seconds)",
                "default": 60,
                "validators": [
                    {
                        "type": "min",
                        "config": {
                            "value": 10
                        }
                    }
                ]
            },
            "enableMetrics": {
                "type": "boolean",
                "label": "Enable Metrics Collection",
                "default": true
            },
            "enableTracing": {
                "type": "boolean",
                "label": "Enable Distributed Tracing",
                "default": false
            },
            "logLevel": {
                "type": "string",
                "label": "Log Level",
                "default": "warn",
            "validators": [
                {
                    "type": "enum",
                    "config": {
                        "values": ["debug", "info", "warn", "error"]
                    }
                }
            ]
            }
        }
    },
    "configTemplate": "endpoint: {{.apiEndpoint}}\nkey: {{.apiKey}}\ntracing: {{.enableTracing}}",
    "cmdTemplate": "agent install --config {{.configUrl}}",
    "configContentType": "application/yaml"
}

### Get the updated agent type
GET {{baseUrl}}/agent-types/{{createdAgentTypeId}}
Authorization: Bearer {{adminToken}}

### Delete the agent type
DELETE {{baseUrl}}/agent-types/{{createdAgentTypeId}}
Authorization: Bearer {{adminToken}}

### --- Template validation: negative cases (expect 400) ---

### Reject unknown ref in configTemplate
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Invalid Config Ref",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "host={{.missing}}",
    "configContentType": "text/plain"
}

### Reject configUrl in configTemplate (only allowed in cmdTemplate)
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "ConfigUrl In Wrong Place",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "url={{.configUrl}}",
    "configContentType": "text/plain"
}

### Reject unknown ref in cmdTemplate
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Invalid Cmd Ref",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "cmdTemplate": "run --flag {{.unknown}}",
    "configContentType": "text/plain"
}

### Reject unparseable template
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Broken Template",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "host={{.host",
    "configContentType": "text/plain"
}

### Reject malformed configContentType
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Bad Mime",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configContentType": "not a mime"
}

### Reject configTemplate set but cmdTemplate empty (coupling)
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Config Only",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "host: {{.host}}",
    "configContentType": "text/plain"
}

### Reject both templates set but cmdTemplate missing configUrl
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Cmd Missing ConfigUrl",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "host: {{.host}}",
    "cmdTemplate": "install --host {{.host}}",
    "configContentType": "text/plain"
}

### --- Template validation: happy paths (expect 200) ---

### Accept both templates with configUrl and default configContentType
# @name templateHappyPath
POST {{baseUrl}}/agent-types
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "name": "Both Templates",
    "configurationSchema": {
        "properties": {
            "host": { "type": "string", "required": true }
        }
    },
    "configTemplate": "host: {{.host}}",
    "cmdTemplate": "agent install --url {{.configUrl}} --host {{.host}}"
}

@templateHappyPathId = {{templateHappyPath.response.body.id}}

### Verify configContentType defaulted to text/plain
GET {{baseUrl}}/agent-types/{{templateHappyPathId}}
Authorization: Bearer {{adminToken}}

### Update templates on the created agent type
PATCH {{baseUrl}}/agent-types/{{templateHappyPathId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
    "configTemplate": "host={{.host}}",
    "configContentType": "text/plain; charset=utf-8"
}

### Cleanup
DELETE {{baseUrl}}/agent-types/{{templateHappyPathId}}
Authorization: Bearer {{adminToken}}
